# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# .env.local is local-only and ignored by git.
# Never commit real secrets. If a secret is pasted into chat, an issue, or a commit,
# treat it as compromised and rotate it before using it again.

# ------------------------------------------------------------------------------
# Minimum viable local setups
# ------------------------------------------------------------------------------

# Frontend-only:
# - No env vars required
# - Run: bun run dev:vite

# Full local API with Upstash:
# REDIS_KV_REST_API_URL="https://your-upstash-instance.upstash.io"
# REDIS_KV_REST_API_TOKEN="your-upstash-rest-token"
# Run: bun run dev

# Full self-host style stack:
# REDIS_URL="redis://default:password@127.0.0.1:6379/0"
# REALTIME_PROVIDER="local"
# REALTIME_WS_PATH="/ws"
# STORAGE_PROVIDER="s3"
# Run: bun run dev or bun run dev:api

# ------------------------------------------------------------------------------
# Core runtime + app origins
# ------------------------------------------------------------------------------

NODE_ENV="development"
API_HOST="0.0.0.0"
API_PORT="3000"
PORT="3000"

# Canonical browser origin used for docs links, share URLs, and runtime config.
APP_PUBLIC_ORIGIN="http://localhost:3000"

# Allowed browser origins for /api/* CORS checks. Comma-separated; supports
# wildcard subdomains such as *.example.com.
API_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# Optional extra app host allowlist entries used by host validation helpers.
API_ALLOWED_HOSTS=""
APP_ALLOWED_HOSTS=""

# Optional aliases still supported by the runtime/config helpers.
PUBLIC_APP_ORIGIN=""
APP_URL=""
NEXT_PUBLIC_APP_URL=""
VITE_APP_PUBLIC_ORIGIN=""

# Optional runtime hints.
API_ENV=""
API_RUNTIME_ENV=""
DEPLOYMENT_TARGET=""
API_URL=""

# ------------------------------------------------------------------------------
# Redis / data backend
# ------------------------------------------------------------------------------

# Recommended for Coolify, Docker, VPS, and local self-host style setups.
REDIS_URL=""

# Upstash REST fallback (recommended for Vercel-compatible or lightweight setups).
REDIS_KV_REST_API_URL=""
REDIS_KV_REST_API_TOKEN=""

# Optional explicit override: redis-url | upstash-rest
REDIS_PROVIDER=""

# ------------------------------------------------------------------------------
# Realtime
# ------------------------------------------------------------------------------

# Recommended self-hosted production/default combination:
# REALTIME_PROVIDER="local"
# REALTIME_WS_PATH="/ws"
REALTIME_PROVIDER=""
REALTIME_WS_PATH="/ws"

# Pusher fallback
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_PUBLIC_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="us3"
PUSHER_FORCE_TLS="true"

# Optional debug logging
REALTIME_DEBUG=""

# ------------------------------------------------------------------------------
# Object storage / cloud sync uploads
# ------------------------------------------------------------------------------

# Recommended self-hosted production/default combination:
# STORAGE_PROVIDER="s3"
#
# Supported values include:
# - s3
# - s3-compatible
# - vercel-blob
STORAGE_PROVIDER=""

# Vercel Blob fallback
BLOB_READ_WRITE_TOKEN=""

# S3-compatible storage (MinIO, R2, Backblaze B2, AWS S3, etc.)
S3_BUCKET=""
S3_REGION=""
S3_ENDPOINT=""
S3_PUBLIC_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_SESSION_TOKEN=""
S3_FORCE_PATH_STYLE=""

# AWS aliases supported by the S3 adapter
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""

# Optional debug logging
STORAGE_DEBUG=""

# ------------------------------------------------------------------------------
# AI providers
# ------------------------------------------------------------------------------

OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""

# Alias also supported by the Google provider selection logic.
GOOGLE_AI_API_KEY=""

# ------------------------------------------------------------------------------
# Media / speech
# ------------------------------------------------------------------------------

ELEVENLABS_API_KEY=""
YOUTUBE_API_KEY=""
YOUTUBE_API_KEY_2=""

# ------------------------------------------------------------------------------
# Telegram bot integration
# ------------------------------------------------------------------------------

TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_WEBHOOK_URL=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_BOT_MODEL=""
TELEGRAM_BOT_API_BASE_URL=""
TELEGRAM_TEST_API_PORT=""

# Scheduled heartbeat route protection
CRON_SECRET=""

# ------------------------------------------------------------------------------
# Cursor Cloud repo agent integration
# ------------------------------------------------------------------------------

CURSOR_API_KEY=""
CURSOR_SDK_MODEL=""
CURSOR_CLOUD_REPO_URL=""
CURSOR_CLOUD_STARTING_REF="main"
CURSOR_CLOUD_AUTO_PR=""

# ------------------------------------------------------------------------------
# IRC bridge
# ------------------------------------------------------------------------------

# Set to 1 to disable IRC bridge connections entirely.
IRC_BRIDGE_DISABLED=""

# ------------------------------------------------------------------------------
# Desktop / local tooling
# ------------------------------------------------------------------------------

TAURI_ENV=""
VITE_PORT="5173"

# Vite runtime overrides if you need the frontend to point at a non-default
# production-style config during local development.
VITE_REALTIME_PROVIDER=""
VITE_REALTIME_WS_PATH=""
VITE_PUSHER_KEY=""
VITE_PUSHER_CLUSTER=""
VITE_PUSHER_FORCE_TLS=""
VITE_VERCEL_ENV=""

# ------------------------------------------------------------------------------
# Platform-injected / informational variables
# ------------------------------------------------------------------------------

# These are usually injected by hosting providers or CI and do not need to be
# set in .env.local. They are listed here because the app recognizes them.
SOURCE_COMMIT=""
GIT_COMMIT_SHA=""
VERCEL=""
VERCEL_ENV=""
VERCEL_URL=""
VERCEL_GIT_COMMIT_SHA=""
COOLIFY_URL=""
COOLIFY_FQDN=""
COOLIFY_BRANCH=""
COOLIFY_APP_ID=""
COOLIFY_SERVICE_ID=""
COOLIFY_RESOURCE_UUID=""
COOLIFY_CONTAINER_NAME=""
